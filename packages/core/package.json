{
  "name": "runcrayon",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/timescale/crayon"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "crayon": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema-ops": {
      "types": "./dist/cli/mcp/lib/schema-ops.d.ts",
      "import": "./dist/cli/mcp/lib/schema-ops.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "skills"
  ],
  "scripts": {
    "build": "tsc --build && vite build dev-ui && chmod +x dist/cli/index.js && rm -rf ./skills && cp -r ../../skills ./skills",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@clack/prompts": "^1.1.0",
    "@dbos-inc/dbos-sdk": "^4.10.15",
    "@mozilla/readability": "^0.6.0",
    "@nangohq/node": "^0.45.1",
    "@tigerdata/mcp-boilerplate": "file:docker/tigerdata-mcp-boilerplate-1.1.0.tgz",
    "ai": "^6.0.116",
    "chokidar": "^4.0.3",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "jiti": "^2.6.1",
    "jose": "^6.2.1",
    "linkedom": "^0.18.12",
    "node-pty": "1.2.0-beta.11",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "react-markdown": "^10.1.0",
    "roughjs": "^4.6.6",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.24.7",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nangohq/frontend": "^0.69.43",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
